# NukkadMart Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=NukkadMart
APP_VERSION=1.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

# MongoDB Configuration (use Atlas or local)
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname
# For Local: mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=nukkadmart

# Upstash Redis Configuration (Serverless)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
REDIS_CART_TTL=1800
REDIS_SESSION_TTL=1800
REDIS_ORDER_TTL=86400

# Groq AI Configuration (Primary - for development)
GROQ_API_KEY=your-groq-api-key
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# AWS Bedrock Configuration (for Amazon Nova - when credits available)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_NOVA_ACT_MODEL_ID=amazon.nova-act-v1:0

# S3 Configuration
S3_BUCKET_NAME=nukkadmart-images
S3_REGION=ap-south-1

# Security
SECRET_KEY=change-this-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Nudge Engine
ABANDONMENT_THRESHOLD=0.70
MAX_DISCOUNT_PERCENT=15.0
MIN_DISCOUNT_PERCENT=5.0